# Azure AD 앱 등록 정보 - 아래 값을 .env 파일에 복사해서 채워주세요
VITE_MSAL_CLIENT_ID=여기에_앱_등록_클라이언트_ID
VITE_MSAL_TENANT_ID=여기에_테넌트_ID

# Teams Incoming Webhook URL (선택)
# Teams 채널 → 커넥터 → Incoming Webhook 에서 생성한 URL을 붙여넣으세요
# 설정하지 않으면 업무 종료 보고를 복사 후 수동 전송 모드로 동작합니다
VITE_TEAMS_WEBHOOK_URL=

# Firebase (Firestore DB)
# Firebase 콘솔 → 프로젝트 설정 → 앱 추가(웹) → 구성에서 복사
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
